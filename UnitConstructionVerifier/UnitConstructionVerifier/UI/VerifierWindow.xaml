<Window x:Class="UnitConstructionVerifier.UI.VerifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unit Construction Verifier"
        Width="1150" Height="780" MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- ── Color Palette ── -->
        <SolidColorBrush x:Key="BgPrimary"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgSurface"      Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgCard"         Color="#313145"/>
        <SolidColorBrush x:Key="AccentBlue"     Color="#7C9EFF"/>
        <SolidColorBrush x:Key="AccentGreen"    Color="#50FA7B"/>
        <SolidColorBrush x:Key="AccentRed"      Color="#FF5555"/>
        <SolidColorBrush x:Key="AccentOrange"   Color="#FFB86C"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="#F8F8F2"/>
        <SolidColorBrush x:Key="TextSecondary"  Color="#AAAACC"/>
        <SolidColorBrush x:Key="BorderColor"    Color="#44445A"/>

        <!-- ── Section Header Style ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <!-- ── Tab Item Style ── -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground"         Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"         Value="{StaticResource BgSurface}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding"            Value="16,10"/>
            <Setter Property="FontSize"           Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                    <Setter Property="Background" Value="{StaticResource BgCard}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Primary Button Style ── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"   Value="#1E1E2E"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="2"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9DB8FF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Secondary Button Style ── -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid Style ── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"          Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="RowBackground"        Value="{StaticResource BgCard}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgSurface}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderColor}"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="CanUserAddRows"       Value="False"/>
            <Setter Property="CanUserDeleteRows"    Value="False"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="{StaticResource BgSurface}"/>
            <Setter Property="Foreground"   Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="12,8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"     Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextBlock.VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="12,6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                    <Setter Property="Foreground" Value="{StaticResource BgPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- ── DataGrid Editing TextBox Style ── -->
        <Style x:Key="DataGridEditingTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        
        <!-- ── Form Label Style ── -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- ── Form TextBox Style ── -->
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ComboBox Style ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgPrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="6,0,24,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Background="{TemplateBinding Background}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Name="Border" 
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Arrow -->
                                                <Path Name="Arrow"
                                                      Grid.Column="1"
                                                      Fill="{StaticResource TextSecondary}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BgSurface}"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource AccentBlue}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource BgSurface}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            
                            <!-- The Popup showing the list -->
                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" 
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinHeight="20"
                                      MinWidth="{Binding Path=ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder"
                                            Background="{StaticResource BgSurface}"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="4"/>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                            <Trigger SourceName="Popup" Property="AllowsTransparency" Value="true">
                                <Setter TargetName="DropDownBorder" Property="CornerRadius" Value="4"/>
                                <Setter TargetName="DropDownBorder" Property="Margin" Value="0,2,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Form ComboBox Style ── -->
        <Style x:Key="FormComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
        </Style>

        <!-- ── ComboBoxItem Style ── -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource BgSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource BgPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource BgPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ── ContextMenu Style ── -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource BgSurface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- ── Reusable ContextMenus ── -->
        <ContextMenu x:Key="SurfaceContextMenu" Style="{StaticResource DarkContextMenu}">
            <MenuItem Header="Open in Inventor" Style="{StaticResource DarkMenuItem}" Click="OnOpenSurfaceInInventor"/>
        </ContextMenu>
        <ContextMenu x:Key="PartContextMenu" Style="{StaticResource DarkContextMenu}">
            <MenuItem Header="Open in Inventor" Style="{StaticResource DarkMenuItem}" Click="OnOpenPartInInventor"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>    <!-- Header & Other Construction specs -->
            <RowDefinition Height="*"/>     <!-- Main Content Tabs -->
            <RowDefinition Height="56"/>    <!-- Footer Actions -->
        </Grid.RowDefinitions>

        <!-- ── Header Bar with Global Specs ── -->
        <Border Grid.Row="0" Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="22" Foreground="{StaticResource AccentBlue}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Unit Construction Verifier"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="IamPathLabel" Foreground="{StaticResource TextSecondary}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="300" ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Global Other Specs (Lip & Curb Rest) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="Global Specs:" Foreground="{StaticResource AccentBlue}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    
                    <!-- Upturned Lip -->
                    <CheckBox x:Name="LipCheckBox" Content="Upturned Lip" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center" Checked="OnLipCheckChanged" Unchecked="OnLipCheckChanged" Margin="0,0,6,0" TabIndex="1"/>
                    <TextBox x:Name="LipHeightBox" Style="{StaticResource FormTextBox}" Width="45" Height="24" TextChanged="OnLipHeightChanged" Margin="0,0,20,0" TabIndex="2"/>

                    <!-- Curb Rest -->
                    <CheckBox x:Name="CurbCheckBox" Content="Curb Rest" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center" Checked="OnCurbCheckChanged" Unchecked="OnCurbCheckChanged" Margin="0,0,6,0" TabIndex="3"/>
                    <TextBox x:Name="CurbHeightBox" Style="{StaticResource FormTextBox}" Width="45" Height="24" TextChanged="OnCurbHeightChanged" TabIndex="4"/>

                    <!-- Vertical separator -->
                    <Border Width="1" Height="20" Background="{StaticResource BorderColor}" Margin="16,0"/>

                    <!-- Edit Mode Toggle -->
                    <CheckBox x:Name="EditModeCheckBox" Content="Edit Mode" Foreground="{StaticResource AccentOrange}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Checked="OnEditModeChanged" Unchecked="OnEditModeChanged" TabIndex="5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main Workspace Tabs ── -->
        <TabControl Grid.Row="1" Background="{StaticResource BgPrimary}" BorderThickness="0" Margin="12,12,12,0">
            
            <!-- ROOF TAB -->
            <TabItem Header="Roof Surfaces">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>   <!-- Sidebar -->
                        <ColumnDefinition Width="*"/>     <!-- Details -->
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgSurface}" CornerRadius="6,0,0,6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,1,0,1">
                        <ListBox x:Name="RoofSurfaceList" Background="Transparent" BorderThickness="0" SelectionChanged="OnRoofSelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="ContextMenu" Value="{StaticResource SurfaceContextMenu}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6" ToolTip="{Binding Segments, StringFormat='Segments: \{0\}'}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PartNumber}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Segments, StringFormat='Segs: \{0\}'}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="0,6,6,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="16">
                        <Grid>
                            <Grid x:Name="RoofDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Expectations Form -->
                                <RowDefinition Height="*"/>      <!-- Parts Grid -->
                            </Grid.RowDefinitions>

                            <!-- Expectations Form -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Casing Panel Expectations (Editable)" Style="{StaticResource SectionHeader}"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Panel Thickness:" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="RoofThicknessText" Style="{StaticResource FormTextBox}" Width="60" TextChanged="OnRoofExpectationsChanged" TabIndex="10"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Ext Skin:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="RoofExteriorGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" Margin="0,0,6,0" TabIndex="11"/>
                                            <ComboBox x:Name="RoofExteriorMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" TabIndex="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Int Liner:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="RoofInteriorGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" Margin="0,0,6,0" TabIndex="13"/>
                                            <ComboBox x:Name="RoofInteriorMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" TabIndex="14"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Channel:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="RoofChannelGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" Margin="0,0,6,0" TabIndex="15"/>
                                            <ComboBox x:Name="RoofChannelMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" TabIndex="16"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Trim:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="RoofTrimGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" Margin="0,0,6,0" TabIndex="17"/>
                                            <ComboBox x:Name="RoofTrimMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnRoofExpectationsChanged" TabIndex="18"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Insulation:" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="RoofInsulationText" Style="{StaticResource FormTextBox}" Width="140" TextChanged="OnRoofExpectationsChanged" TabIndex="19"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Thermal Break:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="RoofThermalCombo" Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}" Width="70" Height="24" SelectionChanged="OnRoofThermalComboChanged" TabIndex="20">
                                                <ComboBoxItem Content="Yes"/>
                                                <ComboBoxItem Content="No"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>

                                <Button Grid.Column="1" Content="Apply Casing to All Roofs" Style="{StaticResource SecondaryButton}" VerticalAlignment="Bottom" Height="28" Click="OnApplyRoofToAll"/>
                            </Grid>

                            <!-- Parts Grid -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Referenced Parts Verification (Scanned Live)" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0"/>
                                    <StackPanel Grid.Column="1" x:Name="RoofSyncButtonsPanel" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Sync Selected to Expected" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,2" Margin="0,0,8,0" Click="OnSyncSelectedRoof"/>
                                        <Button Content="Sync All Mismatches" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,2" Click="OnSyncAllMismatchesRoof"/>
                                    </StackPanel>
                                </Grid>
                                <DataGrid Grid.Row="1" x:Name="RoofPartsGrid" SelectionMode="Extended" ContextMenu="{StaticResource PartContextMenu}">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                                                    <Setter Property="Background" Value="#4C2020"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditPending}" Value="True">
                                                    <Setter Property="Background" Value="#5C4300"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True" Width="3*" MinWidth="180"/>
                                        <DataGridTextColumn Header="Part Type" Binding="{Binding PartType}" IsReadOnly="True" Width="1*" MinWidth="80"/>
                                        <DataGridTextColumn Header="Checked Parameter" Binding="{Binding Parameter}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Expected Spec" Binding="{Binding Expected}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Actual Part Spec" Binding="{Binding NewValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" MinWidth="120" EditingElementStyle="{StaticResource DataGridEditingTextBox}"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText, Mode=OneWay}" IsReadOnly="True" Width="0.8*" MinWidth="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                        
                        <TextBlock x:Name="RoofPlaceholderText" Text="Select a Roof Surface from the list to verify its components." Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Visibility="Visible"/>
                    </Grid>
                </Border>
                </Grid>
            </TabItem>

            <!-- WALL TAB -->
            <TabItem Header="Wall Surfaces">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgSurface}" CornerRadius="6,0,0,6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,1,0,1">
                        <ListBox x:Name="WallSurfaceList" Background="Transparent" BorderThickness="0" SelectionChanged="OnWallSelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="ContextMenu" Value="{StaticResource SurfaceContextMenu}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6" ToolTip="{Binding Segments, StringFormat='Segments: \{0\}'}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PartNumber}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Segments, StringFormat='Segs: \{0\}'}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="0,6,6,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="16">
                        <Grid>
                            <Grid x:Name="WallDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Casing Panel Expectations (Editable)" Style="{StaticResource SectionHeader}"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Panel Thickness:" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="WallThicknessText" Style="{StaticResource FormTextBox}" Width="60" TextChanged="OnWallExpectationsChanged" TabIndex="30"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Paint Style:" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="WallPaintText" Style="{StaticResource FormTextBox}" Width="100" TextChanged="OnWallExpectationsChanged" TabIndex="31"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Ext Skin:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="WallExteriorGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnWallExpectationsChanged" Margin="0,0,6,0" TabIndex="32"/>
                                            <ComboBox x:Name="WallExteriorMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnWallExpectationsChanged" TabIndex="33"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Int Liner:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="WallInteriorGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnWallExpectationsChanged" Margin="0,0,6,0" TabIndex="34"/>
                                            <ComboBox x:Name="WallInteriorMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnWallExpectationsChanged" TabIndex="35"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Channel:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="WallChannelGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnWallExpectationsChanged" Margin="0,0,6,0" TabIndex="36"/>
                                            <ComboBox x:Name="WallChannelMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnWallExpectationsChanged" TabIndex="37"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Insulation:" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="WallInsulationText" Style="{StaticResource FormTextBox}" Width="130" TextChanged="OnWallExpectationsChanged" TabIndex="38"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Thermal Break:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="WallThermalCombo" Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}" Width="70" Height="24" SelectionChanged="OnWallThermalComboChanged" TabIndex="39">
                                                <ComboBoxItem Content="Yes"/>
                                                <ComboBoxItem Content="No"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>

                                <Button Grid.Column="1" Content="Apply Casing to All Walls" Style="{StaticResource SecondaryButton}" VerticalAlignment="Bottom" Height="28" Click="OnApplyWallToAll"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Referenced Parts Verification (Scanned Live)" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0"/>
                                    <StackPanel Grid.Column="1" x:Name="WallSyncButtonsPanel" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Sync Selected to Expected" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,2" Margin="0,0,8,0" Click="OnSyncSelectedWall"/>
                                        <Button Content="Sync All Mismatches" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,2" Click="OnSyncAllMismatchesWall"/>
                                    </StackPanel>
                                </Grid>
                                <DataGrid Grid.Row="1" x:Name="WallPartsGrid" SelectionMode="Extended" ContextMenu="{StaticResource PartContextMenu}">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                                                    <Setter Property="Background" Value="#4C2020"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditPending}" Value="True">
                                                    <Setter Property="Background" Value="#5C4300"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True" Width="3*" MinWidth="180"/>
                                        <DataGridTextColumn Header="Part Type" Binding="{Binding PartType}" IsReadOnly="True" Width="1*" MinWidth="80"/>
                                        <DataGridTextColumn Header="Checked Parameter" Binding="{Binding Parameter}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Expected Spec" Binding="{Binding Expected}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Actual Part Spec" Binding="{Binding NewValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" MinWidth="120" EditingElementStyle="{StaticResource DataGridEditingTextBox}"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText, Mode=OneWay}" IsReadOnly="True" Width="0.8*" MinWidth="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                        
                        <TextBlock x:Name="WallPlaceholderText" Text="Select a Wall Surface from the list to verify its components." Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Visibility="Visible"/>
                    </Grid>
                </Border>
                </Grid>
            </TabItem>

            <!-- BASE & FLOOR TAB -->
            <TabItem Header="Base &amp; Floor">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgSurface}" CornerRadius="6,0,0,6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,1,0,1">
                        <ListBox x:Name="BaseSurfaceList" Background="Transparent" BorderThickness="0" SelectionChanged="OnBaseSelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="ContextMenu" Value="{StaticResource SurfaceContextMenu}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6" ToolTip="{Binding Segments, StringFormat='Segments: \{0\}'}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PartNumber}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Segments, StringFormat='Segs: \{0\}'}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="0,6,6,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="16">
                        <Grid>
                            <Grid x:Name="BaseDetailPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Base, Floor, and Sub-Floor Expectations -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Base &amp; Floor Specs (Editable)" Style="{StaticResource SectionHeader}"/>
                                    <WrapPanel Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Base Height:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="BaseHeightCombo" Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}" Width="80" Height="24" SelectionChanged="OnBaseExpectationsComboChanged" TabIndex="50">
                                                <ComboBoxItem Content="6&quot;"/>
                                                <ComboBoxItem Content="8&quot;"/>
                                                <ComboBoxItem Content="10&quot;"/>
                                                <ComboBoxItem Content="12&quot;"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Base Structural Mat:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="BaseMatCombo" Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}" Width="130" Height="24" SelectionChanged="OnBaseExpectationsComboChanged" TabIndex="51">
                                                <ComboBoxItem Content="STL C CHNL"/>
                                                <ComboBoxItem Content="ALM C CHNL"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Formed Channel:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="FormedChannelGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" Margin="0,0,6,0" TabIndex="52"/>
                                            <ComboBox x:Name="FormedChannelMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" TabIndex="53"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Floor:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="FloorGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" Margin="0,0,6,0" TabIndex="54"/>
                                            <ComboBox x:Name="FloorMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" TabIndex="55"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Sub-Floor:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="SubFloorGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" Margin="0,0,6,0" TabIndex="56"/>
                                            <ComboBox x:Name="SubFloorMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" TabIndex="57"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Perimeter Angle:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="PerimeterAngleGaugeCombo" Style="{StaticResource FormComboBox}" Width="60" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" Margin="0,0,6,0" TabIndex="58"/>
                                            <ComboBox x:Name="PerimeterAngleMaterialCombo" Style="{StaticResource FormComboBox}" Width="140" IsEditable="False" SelectionChanged="OnBaseExpectationsComboChanged" TabIndex="59"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,16,4">
                                            <TextBlock Text="Floor Thermal Break:" Style="{StaticResource FormLabel}"/>
                                            <ComboBox x:Name="FloorThermalCombo" Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}" Width="70" Height="24" SelectionChanged="OnFloorThermalComboChanged" TabIndex="60">
                                                <ComboBoxItem Content="Yes"/>
                                                <ComboBoxItem Content="No"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Referenced Base/Floor Components Scan" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" Margin="0"/>
                                    <StackPanel Grid.Column="1" x:Name="BaseSyncButtonsPanel" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Sync Selected to Expected" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,2" Margin="0,0,8,0" Click="OnSyncSelectedBase"/>
                                        <Button Content="Sync All Mismatches" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,2" Click="OnSyncAllMismatchesBase"/>
                                    </StackPanel>
                                </Grid>
                                <DataGrid Grid.Row="1" x:Name="BasePartsGrid" SelectionMode="Extended" ContextMenu="{StaticResource PartContextMenu}">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMismatch}" Value="True">
                                                    <Setter Property="Background" Value="#4C2020"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditPending}" Value="True">
                                                    <Setter Property="Background" Value="#5C4300"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True" Width="3*" MinWidth="180"/>
                                        <DataGridTextColumn Header="Part Type" Binding="{Binding PartType}" IsReadOnly="True" Width="1*" MinWidth="80"/>
                                        <DataGridTextColumn Header="Checked Parameter" Binding="{Binding Parameter}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Expected Spec" Binding="{Binding Expected}" IsReadOnly="True" Width="1.5*" MinWidth="120"/>
                                        <DataGridTextColumn Header="Actual Part Spec" Binding="{Binding NewValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" MinWidth="120" EditingElementStyle="{StaticResource DataGridEditingTextBox}"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText, Mode=OneWay}" IsReadOnly="True" Width="0.8*" MinWidth="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                        
                        <TextBlock x:Name="BasePlaceholderText" Text="Select a Base/Floor Surface from the list to verify its components." Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Visibility="Visible"/>
                    </Grid>
                </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ── Footer Button Bar ── -->
        <Border Grid.Row="2" Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" x:Name="EditModeFooterPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                    <Button Content="Cancel Changes" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="OnCancelChanges"/>
                    <Button Content="💾  Write Changes to IPT Parts" Style="{StaticResource PrimaryButton}"
                            Background="{StaticResource AccentOrange}" Click="OnWriteChanges"/>
                </StackPanel>
 
                <StackPanel Grid.Column="1" x:Name="NormalModeFooterPanel" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Save Overrides" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="OnSave"/>
                    <Button Content="✓  Run Verification Check" Style="{StaticResource PrimaryButton}"
                            Click="OnVerify"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
